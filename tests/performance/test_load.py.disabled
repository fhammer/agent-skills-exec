"""Performance and load tests using Locust."""

from locust import HttpUser, task, between, events
from locust.runners import MasterRunner
import time
import json


class AgentUser(HttpUser):
    """Simulates a user interacting with the Agent API."""

    # Wait between 1-3 seconds between tasks
    wait_time = between(1, 3)

    def on_start(self):
        """Setup: Create tenant and get API key."""
        # Create a tenant for this user
        response = self.client.post("/api/v1/tenants", json={
            "name": f"LoadTestTenant_{int(time.time())}_{self.user_id()}",
            "api_quota": 10000
        })

        if response.status_code == 201:
            data = response.json()
            self.tenant_id = data["tenant_id"]
            self.api_key = data["api_key"]

            # Set default headers
            self.client.headers.update({
                "X-Tenant-ID": self.tenant_id,
                "X-API-Key": self.api_key
            })
        else:
            self.tenant_id = None
            self.api_key = None

    def user_id(self):
        """Generate a unique user ID for this user instance."""
        return id(self)

    @task(3)
    def chat_conversation(self):
        """Simulate a chat conversation (most common operation)."""
        if not self.api_key:
            return

        self.client.post("/api/v1/agent/chat", json={
            "message": "你好，请介绍一下你自己"
        })

    @task(1)
    def get_health(self):
        """Check health status."""
        self.client.get("/api/v1/health")

    @task(2)
    def list_skills(self):
        """List available skills."""
        if not self.api_key:
            return

        self.client.get("/api/v1/skills")

    @task(1)
    def get_tenant_info(self):
        """Get tenant information."""
        if not self.api_key:
            return

        self.client.get(f"/api/v1/tenants/{self.tenant_id}")


class RecommendationUser(HttpUser):
    """Simulates a user using the recommendation demo."""

    wait_time = between(2, 5)

    def on_start(self):
        """Setup: Create tenant and load products."""
        # Create tenant
        response = self.client.post("/api/v1/tenants", json={
            "name": f"RecommendationTest_{int(time.time())}",
            "api_quota": 10000
        })

        if response.status_code == 201:
            data = response.json()
            self.tenant_id = data["tenant_id"]
            self.api_key = data["api_key"]
            self.user_id = f"user_{int(time.time())}_{id(self)}"

            self.client.headers.update({
                "X-Tenant-ID": self.tenant_id,
                "X-API-Key": self.api_key
            })

            # Load some products
            products = [
                {"product_id": "p_001", "name": "Redmi K70", "category": "手机", "brand": "小米", "price": 2499},
                {"product_id": "p_002", "name": "iQOO Neo9", "category": "手机", "brand": "iQOO", "price": 2299},
                {"product_id": "p_003", "name": "一加 Ace 3", "category": "手机", "brand": "一加", "price": 2599},
            ]

            for product in products:
                self.client.post("/api/v1/ecommerce/products", json=product)

            # Create user
            self.client.post("/api/v1/ecommerce/users", json={
                "user_id": self.user_id,
                "name": "测试用户"
            })

    @task(5)
    def product_inquiry(self):
        """Ask for product recommendations."""
        if not self.api_key:
            return

        messages = [
            "我想买个手机",
            "推荐一款2000元的游戏手机",
            "小米和iQOO哪个好",
            "2000-3000元的手机推荐",
        ]

        import random
        message = random.choice(messages)

        self.client.post("/api/v1/recommendation/chat", json={
            "user_id": self.user_id,
            "message": message
        })

    @task(1)
    def search_products(self):
        """Search for products directly."""
        if not self.api_key:
            return

        self.client.post("/api/v1/recommendation/products", json={
            "user_id": self.user_id,
            "category": "手机",
            "constraints": {"price_min": 2000, "price_max": 3000},
            "limit": 5
        })


class SupportUser(HttpUser):
    """Simulates a customer service user."""

    wait_time = between(3, 8)

    def on_start(self):
        """Setup: Create tenant and orders."""
        response = self.client.post("/api/v1/tenants", json={
            "name": f"SupportTest_{int(time.time())}",
            "api_quota": 10000
        })

        if response.status_code == 201:
            data = response.json()
            self.tenant_id = data["tenant_id"]
            self.api_key = data["api_key"]
            self.user_id = f"user_{int(time.time())}_{id(self)}"

            self.client.headers.update({
                "X-Tenant-ID": self.tenant_id,
                "X-API-Key": self.api_key
            })

            # Create user and orders
            self.client.post("/api/v1/ecommerce/users", json={
                "user_id": self.user_id,
                "name": "测试用户"
            })

            self.client.post("/api/v1/ecommerce/orders", json={
                "order_id": f"ORDER_{int(time.time())}",
                "user_id": self.user_id,
                "status": "shipped",
                "total_amount": 2499,
                "items": [{"name": "Redmi K70", "price": 2499}]
            })

    @task(4)
    def order_inquiry(self):
        """Ask about order status."""
        if not self.api_key:
            return

        self.client.post("/api/v1/support/chat", json={
            "user_id": self.user_id,
            "message": "查一下我的订单"
        })

    @task(3)
    def return_request(self):
        """Request a return."""
        if not self.api_key:
            return

        self.client.post("/api/v1/support/chat", json={
            "user_id": self.user_id,
            "message": "想退货"
        })

    @task(2)
    def policy_inquiry(self):
        """Ask about policies."""
        if not self.api_key:
            return

        questions = [
            "退货要运费吗",
            "退款多久到账",
            "7天无理由是什么",
        ]

        import random
        message = random.choice(questions)

        self.client.post("/api/v1/support/chat", json={
            "user_id": self.user_id,
            "message": message
        })


# ==================== Locust Event Handlers ====================

@events.test_stop.add_listener
def on_test_stop(environment, **kwargs):
    """Output test summary when test stops."""
    if environment.stats.total.fail_ratio > 0.1:
        print(f"WARNING: Failure rate is {environment.stats.total.fail_ratio:.2%}")
    else:
        print(f"SUCCESS: Failure rate is acceptable at {environment.stats.total.fail_ratio:.2%}")

    print(f"\n=== Test Summary ===")
    print(f"Total requests: {environment.stats.total.num_requests}")
    print(f"Failure rate: {environment.stats.total.fail_ratio:.2%}")
    print(f"Response time percentiles:")
    print(f"  50%: {environment.stats.total.get_response_time_percentile(0.5)}ms")
    print(f"  95%: {environment.stats.total.get_response_time_percentile(0.95)}ms")
    print(f"  99%: {environment.stats.total.get_response_time_percentile(0.99)}ms")
    print(f"Requests per second: {environment.stats.total.total_rps:.2f}")


# ==================== Standalone Performance Tests ====================

class StressTestMixin:
    """Mixin for stress testing utilities."""

    def stress_test_chat(self, duration_seconds=60):
        """Run a stress test on chat endpoint."""
        end_time = time.time() + duration_seconds
        success_count = 0
        error_count = 0

        while time.time() < end_time:
            response = self.client.post("/api/v1/agent/chat", json={
                "message": f"Stress test message at {time.time()}"
            })

            if response.status_code == 200:
                success_count += 1
            else:
                error_count += 1

        return {
            "duration": duration_seconds,
            "success": success_count,
            "errors": error_count,
            "rps": (success_count + error_count) / duration_seconds
        }


# ==================== Test Configuration ====================

# To run these tests:
#
# 1. Install locust:
#    pip install locust
#
# 2. Run tests:
#    locust -f tests/performance/test_load.py
#
# 3. Or run headless:
#    locust -f tests/performance/test_load.py --headless --users 100 --spawn-rate 10 --run-time 60s
#
# 4. With different user types:
#    locust -f tests/performance/test_load.py AgentUser
#    locust -f tests/performance/test_load.py RecommendationUser
#    locust -f tests/performance/test_load.py SupportUser
